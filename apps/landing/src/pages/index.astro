---
import '../styles/tokens.css';
import '../styles/landing.css';

const title = 'mindtab — a command line for your brain';
const description =
  "MindTab replaces your new-tab page with a single bar that finds anything you've saved, answers from your own notes, and captures what you're reading. Obsidian's depth, Linear's precision, one keyboard shortcut away.";
const canonical = 'https://mindtab.in/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0a0a0a" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;550;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main>
      <!-- NAV -->
      <div class="nav">
        <div class="wrap nav-inner">
          <div class="logo-inline">
            <svg class="mt-mark" viewBox="0 0 24 24" fill="none">
              <path d="M3 8 C3 6.5, 4 6, 5 6 L9 6 C10 6, 10.5 6.5, 11 7 L12 8.5 L19 8.5 C20.1 8.5, 21 9.4, 21 10.5 L21 18 C21 19.1, 20.1 20, 19 20 L5 20 C3.9 20, 3 19.1, 3 18 Z" stroke="currentColor" stroke-width="1.5" />
              <circle cx="8.5" cy="14" r="1.3" fill="#fafafa" />
              <circle cx="12" cy="11.5" r="1.3" fill="currentColor" />
              <circle cx="15.5" cy="14" r="1.3" fill="currentColor" />
              <circle cx="12" cy="16.5" r="1.3" fill="currentColor" />
              <path d="M8.5 14 L12 11.5 L15.5 14 L12 16.5 Z M12 11.5 L12 16.5" stroke="currentColor" stroke-width="0.9" stroke-opacity="0.5" />
            </svg>
            <span>mindtab</span>
          </div>
          <div class="nav-links">
            <a href="#vault">Vault</a>
            <a href="#assistant">Assistant</a>
            <a href="#today">Today</a>
            <a href="#keyboard">Keyboard</a>
            <a href="#platforms">Platforms</a>
            <a href="#install">Install</a>
          </div>
          <div class="nav-spacer"></div>
          <a href="https://app.mindtab.in" class="btn ghost">Sign in</a>
          <a href="#install" class="btn primary">Add to Chrome</a>
        </div>
      </div>

      <!-- HERO -->
      <section class="hero">
        <div class="wrap">
          <div class="hero-tag">
            <span class="bullet"></span>
            v1.0 · out now for chrome, firefox, arc
          </div>
          <h1>
            A command<br />
            line for<br />
            your <u>brain</u>.
          </h1>
          <p class="hero-sub">
            MindTab replaces your new-tab page with a single bar that finds anything you've saved, answers from your own notes, and captures what you're reading. Obsidian's depth, Linear's precision, one keyboard shortcut away.
          </p>
          <div class="hero-cta">
            <a href="#install" class="btn-lg primary">
              Add to Chrome — free
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
            </a>
            <a href="#" class="btn-lg ghost">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polygon points="5 3 19 12 5 21 5 3" fill="currentColor"></polygon></svg>
              Watch 60s demo
            </a>
          </div>
          <div class="hero-meta">
            <div><span class="k">keyboard</span> ⌘K everywhere</div>
            <div><span class="k">sync</span> encrypted end-to-end</div>
            <div><span class="k">storage</span> local-first</div>
            <div><span class="k">price</span> free for individuals</div>
          </div>
        </div>
      </section>

      <!-- DEMO: DASHBOARD -->
      <section class="demo-wrap">
        <div class="wrap">
          <div class="browser">
            <div class="browser-chrome">
              <div class="browser-dots"><div></div><div></div><div></div></div>
              <div class="browser-tabs">
                <div class="browser-tab active">
                  <span class="favicon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"><path d="M3 8 C3 6.5, 4 6, 5 6 L9 6 C10 6, 10.5 6.5, 11 7 L12 8.5 L19 8.5 C20.1 8.5, 21 9.4, 21 10.5 L21 18 C21 19.1, 20.1 20, 19 20 L5 20 C3.9 20, 3 19.1, 3 18 Z" stroke="currentColor" stroke-width="1.5"></path><circle cx="12" cy="13.5" r="1.6" fill="currentColor"></circle></svg>
                  </span>
                  mindtab
                </div>
                <div class="browser-tab"><span class="favicon" style="color:#999">◐</span>obsidian.md — Daily</div>
                <div class="browser-tab"><span class="favicon" style="color:#999">●</span>Linear — GOAL-142</div>
              </div>
              <div class="browser-url">
                <svg class="lock" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="5" y="11" width="14" height="10" rx="2"></rect><path d="M8 11V7a4 4 0 018 0v4"></path></svg>
                chrome://newtab
              </div>
            </div>

            <div class="dash">
              <div>
                <div class="dash-date">
                  TUE 17 APR 2026 · W16
                  <span class="streak">● 12d streak</span>
                </div>
                <div class="dash-time">09<span class="colon">:</span>41</div>
                <div class="dash-greet">Morning, <strong>Alex</strong>. 4 today. The ship deadline is <span style="color:var(--ink)">6 hours out</span>.</div>

                <div style="margin-top: 36px;">
                  <div class="cmdbar">
                    <svg class="lead" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6l8 0M4 12l16 0M4 18l10 0"></path></svg>
                    <div class="cmd-input">
                      <span id="typed">what did i save about </span><em id="typed-em">worse is better</em><span class="cursor"></span>
                    </div>
                    <div class="cmd-modes">
                      <span id="mode-find">find</span>
                      <span id="mode-ask" class="on">ask</span>
                      <span id="mode-add">add</span>
                    </div>
                    <span class="kbd-key">⌘</span><span class="kbd-key">K</span>
                  </div>
                  <div style="font-family: var(--mono); font-size: 11px; color: var(--text-3); margin-top: 12px; margin-left: 4px; display: flex; gap: 18px;">
                    <span><span class="kbd-key" style="font-size: 9px; min-width:14px; height:14px;">⇥</span> switch mode</span>
                    <span><span class="kbd-key" style="font-size: 9px; min-width:14px; height:14px;">↵</span> send</span>
                    <span><span class="kbd-key" style="font-size: 9px; min-width:14px; height:14px;">\</span> scope</span>
                  </div>
                </div>
              </div>

              <div class="dash-grid">
                <div class="panel">
                  <div class="panel-head">
                    <span>Today</span><span class="count">· 4</span>
                    <div class="spacer"></div>
                    <span class="trail"><span class="kbd">G</span><span class="kbd">T</span></span>
                  </div>
                  <div class="today-item"><span class="check"></span><div><div class="title">Ship MindTab identity doc</div><div class="sub">GOAL-142 · design system v2</div></div><span class="prio p1"></span></div>
                  <div class="today-item"><span class="check"></span><div><div class="title">Morning planning block</div><div class="sub">CAL-08 · workstation</div></div><span class="time now">06:30</span></div>
                  <div class="today-item"><span class="check"></span><div><div class="title">Q3 review with Maya</div><div class="sub">GOAL-139 · bring project data</div></div><span class="time">16:00</span></div>
                  <div class="today-item done"><span class="check"><svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12l5 5L20 6"></path></svg></span><div><div class="title">Read: Gabriel — Worse is Better</div><div class="sub">READ-33 · essay</div></div><span class="time">done</span></div>
                </div>

                <div class="panel">
                  <div class="panel-head"><span>Recent · Vault</span><span class="count">· 248 total</span><div class="spacer"></div><span class="trail"><span class="kbd">G</span><span class="kbd">V</span></span></div>
                  <div class="vault-items">
                    <div class="vault-item">
                      <div class="vault-kind">◆ ESSAY</div>
                      <div class="vault-title">Worse is Better</div>
                      <div class="vault-source">dreamsongs.com · 12 min</div>
                      <div class="vault-sum">Gabriel's argument: simple systems that spread beat correct systems that don't.</div>
                      <div class="vault-links"><span>[[design-philosophy]]</span><span>[[unix]]</span></div>
                    </div>
                    <div class="vault-item">
                      <div class="vault-kind">◇ PODCAST</div>
                      <div class="vault-title">How to think about AI agents</div>
                      <div class="vault-source">Latent Space · 84 min</div>
                      <div class="vault-sum">Swyx walks through the agentic stack. Where memory lives; why tools beat chains.</div>
                      <div class="vault-links"><span>[[ai-agents]]</span><span>[[memory]]</span></div>
                    </div>
                    <div class="vault-item">
                      <div class="vault-kind">◇ BOOK</div>
                      <div class="vault-title">The Timeless Way of Building</div>
                      <div class="vault-source">C. Alexander · Ch. 7</div>
                      <div class="vault-sum">The quality without a name. Pattern language as architecture.</div>
                      <div class="vault-links"><span>[[pattern-language]]</span></div>
                    </div>
                    <div class="vault-item">
                      <div class="vault-kind">◆ NOTE</div>
                      <div class="vault-title">On restraint in product design</div>
                      <div class="vault-source">self · yesterday</div>
                      <div class="vault-sum">Three variations is the refuge of the uncommitted. Pick one, commit.</div>
                      <div class="vault-links"><span>[[design-philosophy]]</span></div>
                    </div>
                  </div>
                </div>

                <div class="panel">
                  <div class="panel-head"><span>Graph</span><div class="spacer"></div><span class="trail"><span class="kbd">G</span><span class="kbd">G</span></span></div>
                  <div class="graph-wrap">
                    <div class="graph">
                      <svg viewBox="0 0 260 260" preserveAspectRatio="xMidYMid meet">
                        <defs><radialGradient id="glow" cx="50%" cy="50%" r="50%"><stop offset="0" stop-color="#fafafa" stop-opacity="0.35"></stop><stop offset="1" stop-color="#fafafa" stop-opacity="0"></stop></radialGradient></defs>
                        <g stroke="#333333" stroke-width="0.75" fill="none" opacity="0.9">
                          <line x1="130" y1="130" x2="78" y2="64"></line>
                          <line x1="130" y1="130" x2="190" y2="70"></line>
                          <line x1="130" y1="130" x2="60" y2="140"></line>
                          <line x1="130" y1="130" x2="200" y2="170"></line>
                          <line x1="130" y1="130" x2="100" y2="210"></line>
                          <line x1="130" y1="130" x2="178" y2="218"></line>
                          <line x1="78" y1="64" x2="190" y2="70"></line>
                          <line x1="60" y1="140" x2="100" y2="210"></line>
                          <line x1="200" y1="170" x2="178" y2="218"></line>
                        </g>
                        <circle cx="78" cy="64" r="3.5" fill="#737373"></circle>
                        <circle cx="190" cy="70" r="3" fill="#737373"></circle>
                        <circle cx="60" cy="140" r="2.5" fill="#737373"></circle>
                        <circle cx="200" cy="170" r="4" fill="#7c6df2"></circle>
                        <circle cx="100" cy="210" r="3" fill="#737373"></circle>
                        <circle cx="178" cy="218" r="2.5" fill="#737373"></circle>
                        <circle cx="130" cy="130" r="28" fill="url(#glow)"></circle>
                        <circle cx="130" cy="130" r="7" fill="#fafafa"></circle>
                        <text x="130" y="166" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#fafafa">design-philosophy</text>
                        <text x="200" y="182" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="8" fill="#7c6df2">ai-agents</text>
                      </svg>
                    </div>
                    <div class="graph-legend">
                      <div><span class="d" style="background:#fafafa"></span> focused</div>
                      <div><span class="d" style="background:#7c6df2"></span> ai-linked</div>
                      <div><span class="d" style="background:#737373"></span> connected</div>
                      <div><span class="d" style="background:#555555"></span> dormant</div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="stats-strip">
                <div class="stat"><div class="k">streak</div><div class="v">12<em> d</em></div><div class="delta">▲ personal best</div></div>
                <div class="stat"><div class="k">saved</div><div class="v">248</div><div class="delta">+11 this week</div></div>
                <div class="stat"><div class="k">tasks live</div><div class="v">8</div><div class="delta down">2 overdue</div></div>
                <div class="stat"><div class="k">asked</div><div class="v">34</div><div class="delta">▲ 18%</div></div>
                <div class="stat"><div class="k">focus today</div><div class="v">2h 14m</div><div class="delta">◉ tracking</div></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- COMMAND-LINE PITCH -->
      <section class="section">
        <div class="wrap">
          <div class="section-head">
            <div class="section-num">01 / PITCH<span class="line"></span></div>
            <div>
              <h2>One bar. <u>Three verbs.</u></h2>
              <p>Every action in MindTab starts with ⌘K and ends with one of three modes. That's the whole grammar. Switch between them with Tab. Nothing else to learn — and nothing else in the way.</p>
            </div>
          </div>

          <div class="mode-tabs" id="mode-tabs">
            <div class="mode-tab" data-mode="find">
              <div class="mode-num">01<span style="color:var(--text-4)">/</span><span>find</span></div>
              <div class="mode-name">Find what you saved.</div>
              <div class="mode-desc">Search your Vault — notes, articles, highlights, links — with full-text, tag, and backlink filters. Under 20ms on 10k items.</div>
              <div class="mode-example"><span class="prompt">find</span>that essay about <em>worse is better</em></div>
            </div>
            <div class="mode-tab active" data-mode="ask">
              <div class="mode-num">02<span style="color:var(--text-4)">/</span><span>ask</span></div>
              <div class="mode-name">Ask your brain.</div>
              <div class="mode-desc">The assistant answers from your Vault, with sources. No web search. No hallucinated summaries. If it's not in your notes, it says so.</div>
              <div class="mode-example"><span class="prompt">ask</span>what did I conclude about <em>modular monoliths</em>?</div>
            </div>
            <div class="mode-tab" data-mode="add">
              <div class="mode-num">03<span style="color:var(--text-4)">/</span><span>add</span></div>
              <div class="mode-name">Capture in one keystroke.</div>
              <div class="mode-desc">Save the current tab, a highlight, a thought. Auto-tagged, auto-summarized, dropped into your graph. No modals. No folders.</div>
              <div class="mode-example"><span class="prompt">add</span>this page to <em>[[ai-agents]]</em></div>
            </div>
          </div>
        </div>
      </section>

      <!-- FEATURE CUTS -->
      <section class="section">
        <div class="wrap">
          <div class="section-head">
            <div class="section-num">02 / SURFACES<span class="line"></span></div>
            <div>
              <h2>Three surfaces. <u>One keyboard.</u></h2>
              <p>The command bar branches into three destinations. Each one is the depth under a verb — and every one is reached with two keys.</p>
            </div>
          </div>

          <!-- VAULT -->
          <div class="feature" id="vault">
            <div class="feat-copy">
              <div class="feat-tag"><span class="dot"></span>Vault · <span style="color:var(--text-3); letter-spacing:0">G&nbsp;V</span></div>
              <h3>Your second brain, <br />with backlinks that mean something.</h3>
              <div class="desc">Every save lands in the Vault — articles, podcasts, books, your own notes — with AI-drafted summaries, auto-extracted tags, and a live backlink graph. It's Obsidian if Obsidian never made you choose a folder.</div>
              <div class="specs">
                <div class="spec"><span class="k">capture</span><span class="v">browser · mobile · email · share sheet</span></div>
                <div class="spec"><span class="k">search</span><span class="v">full-text · tags · time · backlinks</span></div>
                <div class="spec"><span class="k">format</span><span class="v">markdown-native, portable</span></div>
                <div class="spec"><span class="k">storage</span><span class="v">encrypted, exportable in one click</span></div>
              </div>
            </div>

            <div class="feat-vis">
              <div class="vault-vis">
                <div class="vault-vis-head">
                  <div class="search">
                    [[design-philosophy]] <span class="cursor"></span>
                  </div>
                  <div class="chip on">essay · 8</div>
                  <div class="chip">book · 3</div>
                  <div class="chip">note · 5</div>
                </div>
                <div class="vault-vis-grid">
                  <div class="vault-vis-item focused">
                    <div class="kind">◆ ESSAY</div>
                    <div class="t">Worse is Better</div>
                    <div class="s">dreamsongs.com · 12 min</div>
                    <div class="snip">Gabriel's argument: simple systems that spread beat correct systems that don't.</div>
                    <div class="backlink"><span>[[design-philosophy]]</span><span>[[unix]]</span></div>
                  </div>
                  <div class="vault-vis-item">
                    <div class="kind">◆ NOTE</div>
                    <div class="t">On restraint in product design</div>
                    <div class="s">self · yesterday</div>
                    <div class="snip">Three variations is the refuge of the uncommitted.</div>
                    <div class="backlink"><span>[[design-philosophy]]</span></div>
                  </div>
                  <div class="vault-vis-item">
                    <div class="kind">◇ BOOK</div>
                    <div class="t">The Design of Everyday Things</div>
                    <div class="s">Norman · Ch. 2</div>
                    <div class="snip">Affordances. Signifiers. The mapping between control and outcome.</div>
                    <div class="backlink"><span>[[design-philosophy]]</span><span>[[ux]]</span></div>
                  </div>
                  <div class="vault-vis-item">
                    <div class="kind">◆ ESSAY</div>
                    <div class="t">Taste for Makers</div>
                    <div class="s">paulgraham.com · 18 min</div>
                    <div class="snip">Good design is redesign. Good design resembles nature. Good design is hard.</div>
                    <div class="backlink"><span>[[design-philosophy]]</span></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- ASSISTANT -->
          <div class="feature flip" id="assistant">
            <div class="feat-copy">
              <div class="feat-tag"><span class="dot"></span>Assistant · <span style="color:var(--text-3); letter-spacing:0">⌘&nbsp;/</span></div>
              <h3>An assistant that reads <br />only your notes.</h3>
              <div class="desc">Ask anything — the assistant answers from your Vault, grounded, with numbered citations. If the answer isn't in your saved knowledge, it says so. Never invents. Never browses. Never ships your notes to a foundation model.</div>
              <div class="specs">
                <div class="spec"><span class="k">model</span><span class="v">local · private · on-device when possible</span></div>
                <div class="spec"><span class="k">grounding</span><span class="v">your Vault only</span></div>
                <div class="spec"><span class="k">citations</span><span class="v">every claim, every time</span></div>
                <div class="spec"><span class="k">honesty</span><span class="v">says "I don't know" when it doesn't</span></div>
              </div>
            </div>

            <div class="feat-vis">
              <div class="asst-vis">
                <div class="asst-head">
                  <span class="dot"></span>
                  <span>ASK · grounded in your vault</span>
                  <div style="flex:1"></div>
                  <span style="font-family:var(--mono); font-size: 10px; letter-spacing:0; text-transform:none; color:var(--text-4);">248 items · 42 tags</span>
                </div>
                <div class="asst-body">
                  <div class="asst-q">What did I conclude about <em>modular monoliths</em>?</div>
                  <div class="asst-a">
                    <div class="txt">
                      Across three saves in the last quarter, you landed on three tensions. First, that a modular monolith buys you <u>team autonomy without distributed-systems tax</u>, which you called "the only free lunch in architecture." Second, that module boundaries <u>decay in direct proportion to deadline pressure</u> — you cited the Datadog post twice. Third, you noted that <u>the real test is the build graph</u>, not the deploy graph.
                    </div>
                    <div class="asst-sources">
                      <div class="asst-src"><span class="n">1</span><span class="t">Modular Monoliths at Datadog</span><span class="m">datadoghq.com · mar 12</span></div>
                      <div class="asst-src"><span class="n">2</span><span class="t">On boundaries that rot</span><span class="m">self note · feb 28</span></div>
                      <div class="asst-src"><span class="n">3</span><span class="t">The Majestic Monolith</span><span class="m">signalvnoise.com · jan 4</span></div>
                    </div>
                  </div>
                </div>
                <div class="asst-footer">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="2" stroke-linecap="round"><path d="M4 12l8-8 8 8M12 4v16"></path></svg>
                  <div class="input">Ask another, or <em>tab for sources ↗</em></div>
                  <span class="kbd-key">⌘</span><span class="kbd-key">/</span>
                </div>
              </div>
            </div>
          </div>

          <!-- TODAY -->
          <div class="feature" id="today">
            <div class="feat-copy">
              <div class="feat-tag"><span class="dot"></span>Today · <span style="color:var(--text-3); letter-spacing:0">G&nbsp;T</span></div>
              <h3>The one list <br />you actually finish.</h3>
              <div class="desc">Tasks, calendar events, and read-later items collapse into one time-sorted list for today. Progress is implicit: no badges to collect, just what's now and what's next.</div>
              <div class="specs">
                <div class="spec"><span class="k">sources</span><span class="v">tasks · calendar · read · vault</span></div>
                <div class="spec"><span class="k">sort</span><span class="v">time → priority → freshness</span></div>
                <div class="spec"><span class="k">focus</span><span class="v">one task, highlighted</span></div>
                <div class="spec"><span class="k">roll-over</span><span class="v">automatic, with a nudge not a judgement</span></div>
              </div>
            </div>

            <div class="feat-vis">
              <div class="today-vis">
                <div class="today-vis-head">
                  <div class="d">Tue 17 Apr</div>
                  <div class="k">4 remaining · ship by 18:00</div>
                </div>
                <div class="timeline">
                  <div class="tl-row"><div class="tl-time">06:30</div>
                    <div class="tl-card done">
                      <div class="t">Morning run — 8km easy</div>
