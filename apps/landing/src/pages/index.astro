    <script is:inline>
      (function () {
        const states = [
          { mode: 'find', lead: 'find what i saved about ', query: 'worse is better' },
          { mode: 'ask', lead: 'what did i save about ', query: 'worse is better' },
          { mode: 'add', lead: 'save this page to ', query: '[[design-philosophy]]' },
        ];
        const typed = document.getElementById('typed');
        const typedEm = document.getElementById('typed-em');
        const pills = {
          find: document.getElementById('mode-find'),
          ask: document.getElementById('mode-ask'),
          add: document.getElementById('mode-add'),
        };
        if (!typed || !typedEm || !pills.find || !pills.ask || !pills.add) return;

        let i = 1;
        function apply(n) {
          const s = states[n];
          Object.values(pills).forEach((el) => el.classList.remove('on'));
          pills[s.mode].classList.add('on');
          typed.textContent = s.lead;
          typedEm.textContent = s.query;
        }
        setInterval(() => {
          i = (i + 1) % states.length;
          apply(i);
        }, 3200);
      })();

      (function () {
        const tabs = document.querySelectorAll('#mode-tabs .mode-tab');
        tabs.forEach((t) =>
          t.addEventListener('click', () => {
            tabs.forEach((x) => x.classList.remove('active'));
            t.classList.add('active');
          })
        );
      })();
    </script>
