{
  "name": "mindtab",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @mindtab/web dev",
    "dev:landing": "pnpm --filter @mindtab/landing dev",
    "build": "pnpm --filter @mindtab/api-spec build && pnpm --filter @mindtab/shared build && pnpm --filter @mindtab/web build",
    "build:landing": "pnpm --filter @mindtab/landing build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20"
  }
}
